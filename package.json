{
  "name": "meno",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop app scaffold powered by Effect and the Pi SDK",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && pnpm build:renderer && node scripts/copy-static.mjs",
    "build:renderer": "node scripts/build-renderer.mjs && tailwindcss -i src/renderer/styles.css -o dist/renderer/styles.css --minify",
    "clean": "node scripts/clean.mjs",
    "dev": "pnpm build && electron .",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src scripts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "hooks:install": "hk install",
    "hooks:check": "hk check --all",
    "lsp": "typescript-language-server --stdio"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/store": "^0.11.0",
    "effect": "^3.22.0",
    "lucide-react": "^1.25.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.1",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "typescript-language-server": "^5.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.15.1"
}
