{
  "name": "meno",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop app scaffold powered by Effect and the Pi SDK",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "clean": "node scripts/clean.mjs",
    "dev": "pnpm build && electron .",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src scripts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "hooks:install": "hk install",
    "hooks:check": "hk check --all",
    "lsp": "typescript-language-server --stdio"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "effect": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^43.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "typescript-language-server": "^5.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0"
}
